# S3-compatible credentials for Cloudflare R2
# All three are required together. Set these in your shell or CI environment.
# The CLI will NOT read this file — copy to .env and source it, or export directly.

S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Optional — defaults to "auto" for R2
# S3_REGION=auto
