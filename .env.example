# S3-compatible credentials for Cloudflare R2
# All three are required together. The CLI will NOT read this file automatically —
# copy to .env, fill in values, then: source .env

export S3_ACCESS_KEY_ID=your-r2-access-key-id
export S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
export S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Optional — defaults to "auto" for R2
# export S3_REGION=auto
